        "contact": {
          "name": "API Support",
          "url": "https://www.useragentlookup.com/"
        },
        "description": "This API allows users to parse and retrieve information about user agents for free. It has no limitations or rate limiting, enabling unlimited requests by simply calling the appropriate endpoint with the user agent string.",
        "license": {
          "name": "Free to use"
        },
        "servers": [
          {
            "description": "Production server",
            "url": "https://www.useragentlookup.com/api"
          }
